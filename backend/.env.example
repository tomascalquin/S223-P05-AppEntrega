# ========================================
# CONFIGURACIÓN DE SERVIDOR
# ========================================

# Puerto en el que corre el servidor
PORT=3001

# URL base del servidor (para CORS y referencias)
SERVER_URL=http://localhost:3001

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================

# Host del servidor MySQL
DB_HOST=localhost

# Puerto del servidor MySQL
DB_PORT=3306

# Usuario de MySQL
DB_USER=root

# Contraseña de MySQL
DB_PASSWORD=clave123

# Nombre de la base de datos
DB_NAME=appdb

# ========================================
# CONFIGURACIÓN DE JWT (JSON Web Tokens)
# ========================================

# Clave secreta para firmar los JWT
# ⚠️ IMPORTANTE: Usa una clave fuerte y aleatoria en producción
# Genera una: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=mi_clave_secreta_para_jwt_12345

# Tiempo de expiración del Access Token
# Formatos válidos: "2h", "30m", "7d", "1w", "3600" (segundos)
JWT_EXPIRATION=2h

# Tiempo de expiración del Refresh Token
# Se usa para renovar el Access Token sin re-autenticar
JWT_REFRESH_EXPIRATION=7d

# ========================================
# CONFIGURACIÓN DE GOOGLE OAuth
# ========================================

# ID de cliente de Google (obtenido de Google Cloud Console)
GOOGLE_CLIENT_ID=156919733559-vr6q4blfh3ckmc4u4ul1b02epercl20k.apps.googleusercontent.com

# ========================================
# CONFIGURACIÓN DE CORS
# ========================================

# Origen permitido para peticiones CORS desde el frontend
CORS_ORIGIN=http://localhost:5173

# ========================================
# ENTORNO
# ========================================

# Modo de ejecución: "development", "production", "test"
NODE_ENV=development
